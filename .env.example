# Spectral Clip Forge Configuration Template
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Upload Configuration
MAX_UPLOAD_SIZE=524288000  # 500MB in bytes
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=output
ALLOWED_EXTENSIONS=mp4,mov,avi,mkv,mp3,wav,flac,m4a

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=100

# Redis Configuration (for Celery)
REDIS_URL=redis://localhost:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ClamAV Configuration (antivirus)
CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# OAuth (Optional - for user authentication)
OAUTH_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (SQLite by default, PostgreSQL for production)
DATABASE_URL=sqlite:///spectral_clip_forge.db

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Branding
WATERMARK_PATH=static/images/spectral_watermark.png
WATERMARK_OPACITY=0.7

# Processing
MAX_CONCURRENT_JOBS=4
JOB_TIMEOUT=600  # seconds
